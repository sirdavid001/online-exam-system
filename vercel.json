{
  "version": 2,
  "builds": [
    {
      "src": "onlinexam/wsgi.py",
      "use": "@vercel/python",
      "config": { "maxLambdaSize": "15mb", "runtime": "python3.12" }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "onlinexam/wsgi.py"
    }
  ],
  "buildCommand": "python manage.py collectstatic --noinput && python manage.py migrate"
}
